NEXT_PUBLIC_SITE_URL=https://team-lobby.ddns.net

# Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_replace_me
SUPABASE_SERVICE_ROLE_KEY=replace_me_server_only

# Discord IDs allowed to open the dashboard (comma-separated)
ADMIN_DISCORD_USER_IDS=538241496630165515

# Discord server permission verification. Users with an Administrator role can sign in.
DISCORD_GUILD_ID=replace-with-discord-guild-id
DISCORD_BOT_TOKEN=replace-with-server-bot-token

# Must match the local Windows agent .env
CONTROL_AGENT_ID=omar-windows-01
CONTROL_AGENT_SECRET=replace-with-the-same-long-random-secret

# Base64-encoded 32 random bytes. Keep server-only.
CONTROL_PAYLOAD_ENCRYPTION_KEY=replace-with-base64-32-byte-key
